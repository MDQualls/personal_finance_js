generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  LOAN
  INVESTMENT
  ASSET
  LIABILITY
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BudgetType {
  SPENDING_LIMIT
  SAVINGS_GOAL
}

enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringType {
  INCOME
  EXPENSE
}

enum PlaidItemStatus {
  ACTIVE
  ERROR        // Item needs re-authentication
  DISCONNECTED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Account {
  id           String      @id @default(cuid())
  name         String
  type         AccountType
  balance      Int         @default(0) // cents
  currency     String      @default("USD")
  isActive     Boolean     @default(true)
  plaidManaged Boolean     @default(false) // true = Plaid owns transaction posting for this account
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  transactions   Transaction[]
  recurringRules RecurringRule[]
  plaidAccount   PlaidAccount?
}

model Category {
  id       String  @id @default(cuid())
  name     String
  parentId String?
  color    String  @default("#6b7a8d")
  icon     String  @default("tag")
  isIncome Boolean @default(false)
  isSystem Boolean @default(false)
  isActive Boolean @default(true)

  parent       Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]     @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      Budget[]
  subscriptions Subscription[]
  recurringRules RecurringRule[]
}

model Transaction {
  id                 String    @id @default(cuid())
  accountId          String
  amount             Int       // cents; positive = in, negative = out
  date               DateTime
  categoryId         String
  description        String
  notes              String?
  isValidated        Boolean   @default(false)
  isTransfer         Boolean   @default(false)
  needsReview        Boolean   @default(false) // true = imported (CSV/Plaid), category not yet confirmed
  plaidTransactionId String?   @unique // Plaid's transaction ID — used for dedup
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  account      Account   @relation(fields: [accountId], references: [id])
  category     Category  @relation(fields: [categoryId], references: [id])
  tags         Tag[]     @relation("TransactionTags")
  transferFrom Transfer? @relation("TransferFrom")
  transferTo   Transfer? @relation("TransferTo")
}

model Transfer {
  id                String   @id @default(cuid())
  fromTransactionId String   @unique
  toTransactionId   String   @unique
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  fromTransaction Transaction @relation("TransferFrom", fields: [fromTransactionId], references: [id])
  toTransaction   Transaction @relation("TransferTo",   fields: [toTransactionId],   references: [id])
}

model PlaidItem {
  id              String          @id @default(cuid())
  accessToken     String          @unique // encrypted at rest (lib/crypto.ts)
  itemId          String          @unique // Plaid's identifier for the institution connection
  institutionId   String
  institutionName String
  lastSyncedAt    DateTime?
  lastCursor      String?         // Plaid transactions cursor for incremental sync
  status          PlaidItemStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  accounts PlaidAccount[]
}

model PlaidAccount {
  id             String    @id @default(cuid())
  plaidItemId    String
  plaidItem      PlaidItem @relation(fields: [plaidItemId], references: [id])
  plaidAccountId String    @unique // Plaid's account ID
  accountId      String?   @unique // link to our Account once matched/created
  account        Account?  @relation(fields: [accountId], references: [id])
  name           String
  mask           String?   // last 4 digits
  officialName   String?
  type           String    // depository, credit, loan, investment
  subtype        String?   // checking, savings, credit card, etc.
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Budget {
  id         String       @id @default(cuid())
  categoryId String
  amount     Int          // cents
  period     BudgetPeriod @default(MONTHLY)
  budgetType BudgetType   @default(SPENDING_LIMIT)
  startDate  DateTime
  rollover   Boolean      @default(false)
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
}

model Subscription {
  id          String    @id @default(cuid())
  name        String
  amount      Int       // cents
  frequency   Frequency @default(MONTHLY)
  nextDueDate DateTime
  categoryId  String
  notes       String?
  isActive    Boolean   @default(true)
  alertDays   Int       @default(3)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
}

model RecurringRule {
  id           String        @id @default(cuid())
  name         String
  amount       Int           // cents
  frequency    Frequency
  accountId    String
  categoryId   String
  nextDate     DateTime
  type         RecurringType
  isActive     Boolean       @default(true)
  autoPost     Boolean       @default(true)
  notes        String?
  lastPostedAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  account  Account  @relation(fields: [accountId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6b7a8d")

  transactions Transaction[] @relation("TransactionTags")
}

model AIInsight {
  id          String   @id @default(cuid())
  period      String   @unique // e.g. "2026-04"
  prompt      String
  response    Json
  generatedAt DateTime @default(now())
}

model AutoRule {
  id         String   @id @default(cuid())
  pattern    String   // substring or regex pattern
  isRegex    Boolean  @default(false)
  categoryId String
  tagId      String?
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MerchantRule {
  id          String   @id @default(cuid())
  pattern     String
  isRegex     Boolean  @default(false)
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NetWorthRecord {
  id          String   @id @default(cuid())
  month       String   @unique // "yyyy-MM" e.g. "2026-04"
  assets      Int      // cents
  liabilities Int      // cents
  netWorth    Int      // cents
  createdAt   DateTime @default(now())
}
