# Database
DATABASE_URL=postgresql://user:password@db:5432/finance

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-32-plus-char-random-string
NEXTAUTH_URL=http://localhost:3000

# Auth credentials (single-user app)
AUTH_USERNAME=mqualls
# Generate with: node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
AUTH_PASSWORD_HASH=$2b$12$...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Postgres container
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=finance
